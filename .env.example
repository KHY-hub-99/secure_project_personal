# ── 데이터베이스 ──
DATABASE_URL=postgresql+asyncpg://agentshield:agentshield@localhost:5432/agentshield

# ── JWT (반드시 변경) ──
JWT_SECRET_KEY=change-me-in-production

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# ── ChromaDB ──
CHROMADB_PERSIST_PATH=./chromadb_data

# ── Proxy ──
DEFENSE_PROXY_URL=http://localhost:8001
MONITORING_PROXY_URL=http://localhost:8002

# ── LoRA Adapters ──
LORA_RED_PATH=./adapters/lora-red
LORA_JUDGE_PATH=./adapters/lora-judge
LORA_BLUE_PATH=./adapters/lora-blue
